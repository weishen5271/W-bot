# 阿里百炼 (LLM)
DASHSCOPE_API_KEY=your_bailian_api_key
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL_NAME=glm-4.7

# 技能池
E2B_API_KEY=your_e2b_api_key

# 数据库
POSTGRES_DSN=postgresql://agent_user:agent_password@localhost:5432/cybercore_agent
MILVUS_URI=http://localhost:19530

# Agent 行为
CYBERCORE_USER_ID=cli_user
CYBERCORE_THREAD_ID=cli_thread_main
CYBERCORE_MEMORY_COLLECTION=cybercore_long_term_memory_cli
CYBERCORE_RETRIEVE_TOP_K=4
CYBERCORE_LOG_LEVEL=INFO
